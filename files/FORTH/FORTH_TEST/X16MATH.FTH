\ FORTHX16 - MATH HELPER SELF-TEST
\ EXERCISES SGN / RND / RANDOM / POS. (ABS MIN MAX MOD ARE CORE WORDS ALREADY.)
\ REQUIRES THE X16 BUILD. RUN WITH:  INCLUDE X16MATH.FTH

DECIMAL
VARIABLE #FAIL

: CHECK
   2DUP = IF 2DROP ."  OK" CR
   ELSE ."  FAIL GOT=" SWAP . ." WANT=" . 1 #FAIL +! CR THEN ;

: RUN-MATH
   0 #FAIL !
   CR ." == X16 MATH TESTS ==" CR

   ." SGN+   " 5 SGN 1 CHECK
   ." SGN-   " -7 SGN -1 CHECK
   ." SGN0   " 0 SGN 0 CHECK

   \ RND n is in 0..n-1
   ." RNDMAX " 10 RND 10 U< -1 CHECK
   ." RNDMIN " 10 RND 0< 0= -1 CHECK
   ." RANDOM " RANDOM DROP 111 111 CHECK

   \ POS returns the cursor column; put the cursor at column 10 first
   ." POS    " 3 10 LOCATE POS 10 CHECK

   ." ALIVE  " 12345 12345 CHECK
   CR #FAIL @ 0= IF ." ALL MATH TESTS PASSED" ELSE ." MATH FAILURES: " #FAIL @ . THEN CR ;

RUN-MATH
