\ FORTHX16 - COMMANDER X16 HARDWARE SELF-TEST
\ VERIFIES THE X16 EXTENSION WORDS BY WRITING HARDWARE REGISTERS AND
\ READING THEM BACK. REQUIRES THE X16 BUILD (FORTHX16.PRG).
\ RUN WITH:  INCLUDE X16TEST.FTH
\ ADDRESSES ARE DECIMAL (HEX SHOWN IN COMMENTS) BECAUSE NUMBER LITERALS
\ ARE PARSED AT COMPILE TIME AND THE BASE IS DECIMAL HERE.

DECIMAL
VARIABLE #FAIL

: CHECK ( ACTUAL EXPECTED -- )
   2DUP = IF 2DROP ."  OK" CR
   ELSE ."  FAIL GOT=" SWAP . ." WANT=" . 1 #FAIL +! CR THEN ;

CREATE TBUF  16 ALLOT
CREATE TBUF2 16 ALLOT
: TFILL 16 0 DO 65 I + TBUF I + C! LOOP ;

: RUN-X16TESTS
   0 #FAIL !
   CR ." == FORTHX16 X16 HARDWARE TESTS ==" CR

   \ VERA VRAM READ / WRITE ROUND TRIP
   ." VPOKE/VPEEK  "   0 0 65 VPOKE  0 0 VPEEK             65 CHECK
   ." V!W LOW BYTE "   1 256 VADDR 12345 V!W  1 256 VPEEK  57 CHECK  \ 12345 AND 255

   \ SPRITES (VRAM BANK 1, ATTRIBUTES AT 64512 = $FC00)
   ." SPRITE-POS X "   100 120 0 SPRITE-POS  1 64514 VPEEK  100 CHECK  \ $FC02
   ." SPRITE-POS Y "   1 64516 VPEEK                        120 CHECK  \ $FC04
   ." SPRITE-SIZE  "   3 3 0 SPRITE-SIZE     1 64519 VPEEK  240 CHECK  \ $FC07 = $F0
   ." SPRITE-Z     "   3 0 SPRITE-Z          1 64518 VPEEK   12 CHECK  \ $FC06 = $0C
   ." SPRITE-IMAGE "   16384 0 SPRITE-IMAGE  1 64512 VPEEK    0 CHECK  \ $FC00, img $4000

   \ PSG (VRAM BANK 1, VOICE 5 AT 63956 = $F9D4)
   ." PSGFREQ LO   "   1000 5 PSGFREQ        1 63956 VPEEK  232 CHECK  \ 1000 AND 255
   ." PSGVOL       "   32 5 PSGVOL           1 63958 VPEEK  224 CHECK  \ 32 OR $C0
   ." PSGWAV       "   1 5 PSGWAV            1 63959 VPEEK   96 CHECK  \ 1<<6 OR $20

   \ FM (YM2151 + AUDIO ROM API): MUST NOT HANG OR CORRUPT STATE
   ." YM!          "   7 64 YM!                        123 123 CHECK
   ." FMINIT       "   FMINIT                          123 123 CHECK
   ." FMVOL/FMNOTE "   60 0 FMVOL 97 0 FMNOTE          123 123 CHECK

   \ BINARY SAVE / BLOAD ROUND TRIP (DEVICE 8)
   TFILL
   S" TESTX16.BIN" 8 TBUF TBUF 16 + SAVE
   S" TESTX16.BIN" 8 TBUF2 BLOAD
   ." SAVE/BLOAD   "   TBUF2 C@          65 CHECK
   ." SAVE/BLOAD+2 "   TBUF2 2 + C@      67 CHECK

   CR #FAIL @ 0= IF ." ALL X16 TESTS PASSED" ELSE ." X16 FAILURES: " #FAIL @ . THEN CR ;

RUN-X16TESTS
