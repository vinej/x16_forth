\ FORTHX16 - INTERACTIVE SPRITE DEMO
\ DRAWS A 16x16 WHITE SPRITE AND MOVES IT WITH THE CURSOR KEYS.
\ REQUIRES THE X16 BUILD. RUN WITH:  INCLUDE X16SPRITE.FTH
\ CLOSE THE EMULATOR (OR RESET) TO STOP - THE MOVE LOOP RUNS FOREVER.

DECIMAL
VARIABLE SX  320 SX !
VARIABLE SY  240 SY !

\ FILL 128 BYTES AT VRAM $4000 WITH PALETTE INDEX 1 (WHITE) -> 16x16 4BPP SPRITE
: SPRIMG  0 16384 VADDR  128 0 DO 17 V! LOOP ;

: SETUP
   SPRIMG
   16384 0 SPRITE-IMAGE     \ SPRITE 0 IMAGE AT VRAM $4000
   1 1 0 SPRITE-SIZE        \ 16 X 16
   3 0 SPRITE-Z             \ Z-DEPTH 3 = IN FRONT
   SX @ SY @ 0 SPRITE-POS
   SPRITES-ON ;

\ CURSOR KEY PETSCII CODES: RIGHT=29 LEFT=157 DOWN=17 UP=145
: MOVELOOP
   BEGIN
      KEY
      DUP 29  = IF SX @ 8 + SX ! THEN
      DUP 157 = IF SX @ 8 - SX ! THEN
      DUP 17  = IF SY @ 8 + SY ! THEN
      DUP 145 = IF SY @ 8 - SY ! THEN
      DROP
      SX @ SY @ 0 SPRITE-POS
   AGAIN ;

SETUP
CR S" USE THE CURSOR KEYS TO MOVE THE SPRITE" TYPE CR
MOVELOOP
