\ FORTHX16 - TILEMAP SELF-TEST (LAYER 1 TEXT SCREEN)
\ WRITES TILES WITH TILE, READS THEM BACK WITH TDATA / TATTR, AND CROSS-CHECKS
\ THE (0,0) CELL DIRECTLY VIA VPEEK AT MAPBASE<<9.
\ REQUIRES THE X16 BUILD. RUN WITH:  INCLUDE X16TILE.FTH

DECIMAL
VARIABLE #FAIL
VARIABLE TC
VARIABLE TA
VARIABLE V0

: CHECK
   2DUP = IF 2DROP ."  OK" CR
   ELSE ."  FAIL GOT=" SWAP . ." WANT=" . 1 #FAIL +! CR THEN ;

\ read VERA_L1_MAPBASE and return the (bank addr) of tile cell (0,0)
: MAPADDR 40757 C@ DUP 7 RSHIFT SWAP 127 AND 512 * ;

: RUN-TILE
   0 #FAIL !

   \ write two tiles, then sample everything BEFORE any printing scrolls the screen
   10 5 65 7 TILE
   0 0 66 3 TILE
   10 5 TDATA TC !
   10 5 TATTR TA !
   MAPADDR VPEEK V0 !

   CR ." == X16 TILE TESTS ==" CR
   ." TDATA  " TC @ 65 CHECK
   ." TATTR  " TA @ 7 CHECK
   ." AT 0,0 " V0 @ 66 CHECK
   ." ALIVE  " 12345 12345 CHECK
   CR #FAIL @ 0= IF ." ALL TILE TESTS PASSED" ELSE ." TILE FAILURES: " #FAIL @ . THEN CR ;

RUN-TILE
