\ FORTHX16 - BITMAP GRAPHICS SELF-TEST (KERNAL GRAPH API)
\ DRAWS SHAPES IN 320x240 MODE, READS PIXELS BACK FROM VRAM AND CHECKS THEM.
\ REQUIRES THE X16 BUILD. RUN WITH:  INCLUDE X16GFX.FTH
\ THE 320x240x256 BITMAP IS AT VRAM $0:0000, 320 BYTES/ROW, 1 BYTE/PIXEL,
\ SO PIXEL X,Y IS AT OFFSET Y*320+X IN BANK 0.

DECIMAL
VARIABLE #FAIL
VARIABLE V1
VARIABLE V2
VARIABLE V3
VARIABLE V4
VARIABLE V5
VARIABLE V6

: CHECK
   2DUP = IF 2DROP ."  OK" CR
   ELSE ."  FAIL GOT=" SWAP . ." WANT=" . 1 #FAIL +! CR THEN ;

\ VRAM offset of pixel X,Y in bank 0
: PX 320 * + ;

\ read the color of pixel X,Y
: RDPX PX 0 SWAP VPEEK ;

: RUN-GFX
   0 #FAIL !
   GINIT GCLS

   100 50 5 PSET
   0 0 50 0 7 LINE
   10 10 20 20 3 RECT
   30 30 40 40 4 FRAME
   50 50 70 70 6 OVAL
   80 50 100 70 2 RING

   100 50 RDPX V1 !
   25 0   RDPX V2 !
   15 15  RDPX V3 !
   30 30  RDPX V4 !
   60 60  RDPX V5 !
   90 60  RDPX V6 !

   0 SCREEN
   CR ." == X16 GRAPHICS TESTS ==" CR
   ." PSET  " V1 @ 5 CHECK
   ." LINE  " V2 @ 7 CHECK
   ." RECT  " V3 @ 3 CHECK
   ." FRAME " V4 @ 4 CHECK
   ." OVAL  " V5 @ 6 CHECK
   ." RING  " V6 @ 0 CHECK
   ." ALIVE " 12345 12345 CHECK
   CR #FAIL @ 0= IF ." ALL GRAPHICS TESTS PASSED" ELSE ." GFX FAILURES: " #FAIL @ . THEN CR ;

RUN-GFX
