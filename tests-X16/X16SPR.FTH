\ FORTHX16 - BASIC-COMPATIBLE SPRITE COMMANDS SELF-TEST
\ EXERCISES MOVSPR / SPRMEM / SPRITE AND READS THE SPRITE ATTRIBUTES BACK.
\ REQUIRES THE X16 BUILD. RUN WITH:  INCLUDE X16SPR.FTH
\ SPRITE 0 ATTRIBUTES ARE IN VRAM BANK 1 AT 64512 ($FC00), 8 BYTES.

DECIMAL
VARIABLE #FAIL

: CHECK
   2DUP = IF 2DROP ."  OK" CR
   ELSE ."  FAIL GOT=" SWAP . ." WANT=" . 1 #FAIL +! CR THEN ;

: RUN-SPR
   0 #FAIL !
   CR ." == X16 SPRITE (BASIC) TESTS ==" CR

   0 100 120 MOVSPR
   ." MOVSPR X  " 1 64514 VPEEK 100 CHECK
   ." MOVSPR Y  " 1 64516 VPEEK 120 CHECK

   0 0 16384 SPRMEM
   ." SPRMEM B0 " 1 64512 VPEEK 0 CHECK
   ." SPRMEM B1 " 1 64513 VPEEK 2 CHECK

   0 3 SPRITE
   ." SPRITE Z  " 1 64518 VPEEK 12 CHECK
   ." SPR LAYER " 40745 C@ 64 AND 64 CHECK

   ." ALIVE     " 12345 12345 CHECK
   CR #FAIL @ 0= IF ." ALL SPRITE TESTS PASSED" ELSE ." SPR FAILURES: " #FAIL @ . THEN CR ;

RUN-SPR
