\ FORTHX16 - BITMAP TEXT SELF-TEST (GTEXT = BASIC CHAR)
\ DRAWS A STRING INTO THE BITMAP AND CONFIRMS PIXELS WERE SET.
\ REQUIRES THE X16 BUILD. RUN WITH:  INCLUDE X16CHAR.FTH

DECIMAL
VARIABLE #FAIL
VARIABLE PIX

: CHECK
   2DUP = IF 2DROP ."  OK" CR
   ELSE ."  FAIL GOT=" SWAP . ." WANT=" . 1 #FAIL +! CR THEN ;

: PX 320 * + ;
: RDPX PX 0 SWAP VPEEK ;

\ OR together the pixels of an 80-wide by 40-tall block at the top-left corner
: TXTPIX 0 40 0 DO 80 0 DO I J RDPX OR LOOP LOOP ;

: RUN-CHAR
   0 #FAIL !
   GINIT GCLS
   0 20 5 S" ABC" GTEXT
   TXTPIX PIX !
   0 SCREEN
   CR ." == X16 CHAR TESTS ==" CR
   ." DREW  " PIX @ 0<> -1 CHECK
   ." ALIVE " 12345 12345 CHECK
   CR #FAIL @ 0= IF ." ALL CHAR TESTS PASSED" ELSE ." CHAR FAILURES: " #FAIL @ . THEN CR ;

RUN-CHAR
