# ─── Third-party tools (not project source) ─────────────────────────────
# Assembler, X16 emulator, and VICE C64 emulator — large vendored binaries
# and their scratch (disk images, ROM dumps, symbol files). Excluded from the
# repo; the working copies stay on disk. Build scripts reference .\asm\acme.exe
# (kept) and .\vice\bin\cartconv.
acme/
emulator/
vice/
asm/

# ─── ACME build outputs (regenerated by the make*.bat scripts) ───────────
# Several of these are already committed; listing them documents intent and
# stops fresh/variant builds from being re-added. Run `git rm --cached <file>`
# to drop the existing copies from the index.
/forthx16.prg
/forthx16816.prg
/fortht.prg
/forthx16rom.bin
/forthcart.bin
/boot2.rom
/fortht.rom
/fortht.crt
/loader.prg
/loader32.prg
/forthx16.sym

# WIDEDICT / far-header build variants (buildx16prg816w/wr/wf.asm)
/forthx16816w.prg
/forthx16816wr.prg
/forthx16816wf.prg
# symbols.txt is a deliberately committed build artifact — do NOT ignore it.

# ─── version/<name>/ build working files ─────────────────────────────────
# The release binaries ARE committed (many users can't build them). But the
# copyrighted Commander X16 ROM must NEVER go to GitHub: the 256 KB Bank9
# images embed the pristine KERNAL/BASIC ROM, and r49.bin IS that ROM base.
version/**/r49.bin
version/ForthX16_6502Bank9/ForthX16_6502Bank9.bin
version/ForthX16_816Bank9/ForthX16_816Bank9.bin
version/**/_*.bin
version/**/*.tmp

# ─── OS / editor junk ───────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
*~
*.swp
*.bak
.vscode/
.idea/

# third-party X16 reference docs (local dev only, not for publishing)
/doc/Commander X16 Programmer's Reference Guide.pdf
/doc/X16 Reference - *
